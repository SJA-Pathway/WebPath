{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/paths/layout,_N_T_/paths/[pathSlug]/layout,_N_T_/paths/[pathSlug]/page,_N_T_/paths/frontend"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/paths/$d$pathSlug/__PAGE__",
    "/paths/$d$pathSlug",
    "/paths",
    "/_index"
  ]
}